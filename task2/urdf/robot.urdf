<?xml version="1.0"?>
<robot name="diff_drive_robot">

  <!-- MATERIALS -->
  <material name="orange">
    <color rgba="1.0 0.5 0.0 1.0"/>
  </material>
  <material name="black">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>
  <material name="grey">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>

  <!-- BASE FOOTPRINT -->
  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/> 
  </joint>

  <!-- BASE LINK -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 -1.5708"/>
      <geometry>
        <mesh filename="file:///home/ayush/ros2_ws/src/task2/meshes/bot_body.stl"
              scale="0.15 0.15 0.15"/>
      </geometry>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 -1.5708"/>
      <geometry>
        <mesh filename="file:///home/ayush/ros2_ws/src/task2/meshes/bot_body.stl"
              scale="0.16 0.16 0.16"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="2.0"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.1" ixy="0.0" ixz="0.0"
               iyy="0.1" iyz="0.0"
               izz="0.1"/>
    </inertial>
  </link>

  <gazebo reference="base_link">
    <material>Gazebo/GreyTransparent</material>
  </gazebo>

  <!-- LEFT WHEEL -->
  <joint name="joint_wheel_left" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_left"/>
    <origin xyz="0 0.1875 -0.15" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="wheel_left">
    <visual>
      <geometry>
        <mesh filename="file:///home/ayush/ros2_ws/src/task2/meshes/wheel.stl"
              scale="0.38 0.38 0.38"/>
      </geometry>
      <material name="black"/>
    </visual>

    <collision>as soon as i launched the launch file, my terminal was flooded with [ODOMETRY ENGINE] messages
      <geometry>
        <mesh filename="file:///home/ayush/ros2_ws/src/task2/meshes/wheel.stl"
              scale="0.38 0.38 0.38"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="0.3"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.001" ixy="0" ixz="0"
               iyy="0.001" iyz="0"
               izz="0.001"/>
    </inertial>
  </link>

  <gazebo reference="wheel_left">
    <material>Gazebo/Black</material>
  </gazebo>

  <!-- RIGHT WHEEL -->
  <joint name="joint_wheel_right" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_right"/>
    <origin xyz="0 -0.1875 -0.15" rpy="1.5708 0 0"/>
    <axis xyz="0 0 -1"/>
  </joint>

  <link name="wheel_right">
    <visual>
      <geometry>
        <mesh filename="file:///home/ayush/ros2_ws/src/task2/meshes/wheel.stl"
              scale="0.38 0.38 0.38"/>
      </geometry>
      <material name="black"/>
    </visual>

    <collision>
      <geometry>
        <mesh filename="file:///home/ayush/ros2_ws/src/task2/meshes/wheel.stl"
              scale="0.38 0.38 0.38"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="0.3"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.001" ixy="0" ixz="0"
               iyy="0.001" iyz="0"
               izz="0.001"/>
    </inertial>
  </link>

  <gazebo reference="wheel_right">
    <material>Gazebo/Black</material>
  </gazebo>

  <!-- FRONT CASTER PART -->
  <joint name="joint_caster_part_front" type="continuous">
    <parent link="base_link"/>
    <child link="caster_part_front"/>
    <origin xyz="0.125 0 -0.15" rpy="-1.5708 0 -1.5708"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="caster_part_front">
    <visual>
      <geometry>
        <mesh filename="file:///home/ayush/ros2_ws/src/task2/meshes/caster_part.stl"
              scale="0.3 0.3 0.3"/>
      </geometry>
      <material name="grey"/>
    </visual>

    <collision>
      <geometry>
        <mesh filename="file:///home/ayush/ros2_ws/src/task2/meshes/caster_part.stl"
              scale="0.3 0.3 0.3"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0"
               iyy="0.0001" iyz="0"
               izz="0.0001"/>
    </inertial>
  </link>

  <gazebo reference="caster_part_front">
    <material>Gazebo/Grey</material>
  </gazebo>

  <!-- FRONT CASTER WHEEL -->
  <joint name="joint_caster_wheel_front" type="continuous">
    <parent link="caster_part_front"/>
    <child link="caster_wheel_front"/>
    <origin xyz="0 0.044 0.018" rpy="-1.5708 0 -1.5708"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="caster_wheel_front">
    <visual>
      <geometry>
        <mesh filename="file:///home/ayush/ros2_ws/src/task2/meshes/caster_wheel.stl"
              scale="0.3 0.3 0.3"/>
      </geometry>
      <material name="black"/>
    </visual>

    <collision>
      <geometry>
        <mesh filename="file:///home/ayush/ros2_ws/src/task2/meshes/caster_wheel.stl"
              scale="0.3 0.3 0.3"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0"
               iyy="0.0001" iyz="0"
               izz="0.0001"/>
    </inertial>
  </link>
  
    <!-- REAR CASTER PART -->
  <joint name="joint_caster_part_rear" type="continuous">
    <parent link="base_link"/>
    <child link="caster_part_rear"/>
    <origin xyz="-0.175 0 -0.15" rpy="-1.5708 0 -1.5708"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="caster_part_rear">
    <visual>
      <geometry>
        <mesh filename="file:///home/ayush/ros2_ws/src/task2/meshes/caster_part.stl"
              scale="0.3 0.3 0.3"/>
      </geometry>
      <material name="grey"/>
    </visual>

    <collision>
      <geometry>
        <mesh filename="file:///home/ayush/ros2_ws/src/task2/meshes/caster_part.stl"
              scale="0.3 0.3 0.3"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0"
               iyy="0.0001" iyz="0"
               izz="0.0001"/>
    </inertial>
  </link>

  <gazebo reference="caster_part_rear">
    <material>Gazebo/Grey</material>
  </gazebo>
  
    <!-- REAR CASTER WHEEL -->
  <joint name="joint_caster_wheel_rear" type="continuous">
    <parent link="caster_part_rear"/>
    <child link="caster_wheel_rear"/>
    <origin xyz="0 0.044 0.018" rpy="-1.5708 0 -1.5708"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="caster_wheel_rear">
    <visual>
      <geometry>
        <mesh filename="file:///home/ayush/ros2_ws/src/task2/meshes/caster_wheel.stl"
              scale="0.3 0.3 0.3"/>
      </geometry>
      <material name="black"/>
    </visual>

    <collision>
      <geometry>
        <mesh filename="file:///home/ayush/ros2_ws/src/task2/meshes/caster_wheel.stl"
              scale="0.3 0.3 0.3"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0"
               iyy="0.0001" iyz="0"
               izz="0.0001"/>
    </inertial>
  </link>
  
  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link= "laser_frame"/>
    <origin xyz="0 0 0.15" rpy = "0 0 0"/>
  </joint>

  <link name="laser_frame">
    <visual>
      <geometry>
        <cylinder radius="0.04" length="0.04"/>
      </geometry>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.04" length="0.04"/>
      </geometry>
    </collision>
  </link>

  <gazebo>
    <plugin name="differential_drive_controller"
            filename="libgazebo_ros_diff_drive.so">
      <ros>
        <namespace>/</namespace>
      </ros>
      <left_joint>joint_wheel_left</left_joint>
      <right_joint>joint_wheel_right</right_joint>
      <wheel_separation>0.35</wheel_separation>
      <wheel_diameter>0.14</wheel_diameter>
      <max_wheel_torque>20</max_wheel_torque>
      <max_wheel_acceleration>1.0</max_wheel_acceleration>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>true</publish_wheel_tf>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_link</robot_base_frame>
    </plugin>
  </gazebo>

  <gazebo reference="laser_frame">
    <material>Gazebo/Black</material>
    <sensor name="laser" type="ray">
      <visualize>true</visualize>
      <always_on>true</always_on>
      <update_rate>10</update_rate>
      <ray> <!-- specify parameters of virtual sensor-->
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.35</min>
          <max>5</max>
          <resolution>0.1</resolution>
        </range>
      </ray>
      <plugin name="laser_controller" filename="libgazebo_ros_ray_sensor.so">
        <ros>
          <argument>~/out:=/scan</argument>
        </ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>laser_frame</frame_name>
      </plugin>
    </sensor>
  </gazebo>
</robot>
